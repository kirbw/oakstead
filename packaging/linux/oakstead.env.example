# Runtime data location.
OAKSTEAD_DATA_DIR=/var/lib/oakstead

# Use 127.0.0.1 for local-only defaults or 0.0.0.0 for LAN defaults.
# To force LAN access regardless of the saved setting, uncomment HOST below.
# HOST=0.0.0.0
OAKSTEAD_DEFAULT_HOST=0.0.0.0
OAKSTEAD_DEFAULT_PORT=3000

# Source installs can keep the Git-based updater.
OAKSTEAD_UPDATE_MODE=git
